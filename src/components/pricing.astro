---
import { Tick } from "@/components/ui/icons";

const { plan } = Astro.props;
---

<style>
  .pricing-card {
    border: 1px solid var(--theme-outline-variant);
    border-radius: 1rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    background: var(--theme-surface-surface-container);
    transition: all 0.3s ease;
  }

  .pricing-card.popular {
    border-color: var(--theme-primary-primary);
    background: var(--theme-primary-primary);
    color: var(--theme-primary-on-primary);
    transform: scale(1.05);
  }

  .pricing-card:hover:not(.popular) {
    border-color: var(--palette-grey-300);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .pricing-name {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: inherit;
  }

  .pricing-price {
    font-size: 2.5rem;
    font-weight: 600;
    margin: 0.5rem 0;
    color: inherit;
  }

  .pricing-period {
    font-size: 0.9rem;
    color: inherit;
    opacity: 0.8;
  }

  .pricing-card.popular .pricing-name,
  .pricing-card.popular .pricing-price,
  .pricing-card.popular .pricing-period {
    color: var(--theme-primary-on-primary);
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pricing-feature {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: 0.95rem;
    color: inherit;
  }

  .pricing-feature :global(svg) {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .pricing-card.popular .pricing-feature {
    color: var(--theme-primary-on-primary);
  }

  .pricing-button {
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    border: none;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
    width: 100%;
  }

  .pricing-card.popular .pricing-button {
    background: var(--theme-primary-on-primary);
    color: var(--theme-primary-primary);
  }

  .pricing-card.popular .pricing-button:hover {
    opacity: 0.9;
  }

  .pricing-card:not(.popular) .pricing-button {
    background: var(--theme-primary-primary);
    color: var(--theme-primary-on-primary);
  }

  .pricing-card:not(.popular) .pricing-button:hover {
    background: var(--theme-button-primary-hover);
  }
</style>

<div class={`pricing-card ${plan.popular ? 'popular' : ''}`}>
  <div class="pricing-header">
    <h3 class="pricing-name">{plan.name}</h3>
    <div class="pricing-price">
      {typeof plan.price === "object" ? plan.price.monthly : plan.price}
    </div>
    {typeof plan.price === "object" && (
      <p class="pricing-period">{plan.price.annual} / year</p>
    )}
  </div>

  <ul class="pricing-features">
    {
      plan.features.map((item) => (
        <li class="pricing-feature">
          <Tick />
          <span>{item}</span>
        </li>
      ))
    }
  </ul>

  <button class="pricing-button">
    {plan.button.text || "Get Started"}
  </button>
</div>
