---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  {
    title: "Services",
    path: "/#features",
  },
  {
    title: "About",
    path: "/about",
  },
  {
    title: "Blog",
    path: "/blog",
  },
  {
    title: "Contact",
    path: "/contact",
  },
];
---

<style>
  .header-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: var(--theme-surface-surface);
    z-index: 140;
    border-bottom: 1px solid var(--theme-outline-variant);
    backdrop-filter: blur(10px);
    background-color: rgba(255, 255, 255, 0.8);
  }

  header {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    align-items: center;
    padding-inline: 3rem;
    padding-block: 1rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .logo {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--theme-surface-on-surface);
    text-decoration: none;
    white-space: nowrap;
  }

  nav {
    flex: 1;
  }

  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    align-items: center;
  }

  nav a {
    color: var(--theme-surface-on-surface-variant);
    padding: 0.6em 1.2em;
    border-radius: 999px;
    transition: all 0.15s ease-out;
    text-decoration: none;
    white-space: nowrap;
    font-size: 0.95rem;
  }

  nav a:hover,
  nav a:focus-visible {
    background: var(--theme-nav-button-hover);
    color: var(--theme-surface-on-surface);
  }

  .nav-buttons {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-left: auto;
  }

  .menu-checkbox {
    display: none;
  }

  .menu-button {
    display: none;
  }

  .menu-close {
    display: none;
  }

  @media (width < 768px) {
    .nav-buttons {
      margin-left: 0;
      gap: 0.25rem;
    }

    nav {
      display: none;
    }

    .menu-button {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 3rem;
      height: 3rem;
      border-radius: 50%;
      background: transparent;
      border: 1px solid transparent;
      cursor: pointer;
      font-size: 1.8rem;
      color: var(--theme-surface-on-surface);
      line-height: 1;
    }

    .header-wrapper:has(.menu-checkbox:checked) {
      background: #000;
      border-bottom-color: transparent;
      backdrop-filter: none;
      background-color: #000;
    }

    .header-wrapper:has(.menu-checkbox:checked) .logo {
      color: #fff;
    }

    .header-wrapper:has(.menu-checkbox:checked) .menu-button {
      color: #fff;
      border-color: rgba(255, 255, 255, 0.35);
      background: rgba(255, 255, 255, 0.08);
    }

    .menu-checkbox:checked + nav {
      position: fixed;
      inset: 0;
      left: 0;
      right: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: #000;
      z-index: 130;
    }

    .menu-checkbox:checked + nav .menu-close {
      display: inline-flex;
      position: fixed;
      top: 1rem;
      right: 1rem;
      width: 3rem;
      height: 3rem;
      align-items: center;
      justify-content: center;
      border-radius: 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.5);
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
      font-size: 2rem;
      line-height: 1;
      cursor: pointer;
      z-index: 131;
    }

    .menu-checkbox:checked + nav ul {
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 0.75rem;
      width: 100%;
      min-height: 100dvh;
      padding-top: 5rem;
      padding-bottom: 2rem;
    }

    .menu-checkbox:checked + nav a {
      font-size: 1.6rem;
      font-weight: 600;
      color: #fff;
      padding: 0.7rem 1.5rem;
      border-radius: 0.75rem;
      border-bottom: none;
      letter-spacing: 0.01em;
    }

    .menu-checkbox:checked + nav a:hover,
    .menu-checkbox:checked + nav a:focus-visible {
      background: rgba(255, 255, 255, 0.12);
      color: #fff;
    }

    header {
      padding-inline: 1rem;
    }

    .logo {
      font-size: 1.1rem;
    }
  }
</style>

<div class="header-wrapper">
  <header>
    <a href="/" class="logo">WMS Discovery</a>
    <Astronav>
      <input class="menu-checkbox" type="checkbox" id="menu-checkbox" />
      <nav>
        <label class="menu-close" for="menu-checkbox" aria-label="Close menu">×</label>
        <ul>
          {
            menuitems.map((item) => (
              <li>
                <a href={item.path}>{item.title}</a>
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="nav-buttons">
        <label class="menu-button" for="menu-checkbox">
          <span>☰</span>
        </label>
      </div>
    </Astronav>
  </header>
</div>
