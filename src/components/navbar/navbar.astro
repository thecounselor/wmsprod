---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  {
    title: "Services",
    path: "/",
  },
  {
    title: "About",
    path: "/about",
  },
  {
    title: "Blog",
    path: "/blog",
  },
  {
    title: "Contact",
    path: "/contact",
  },
];
---

<style>
  .header-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: var(--theme-surface-surface);
    z-index: 100;
    border-bottom: 1px solid var(--theme-outline-variant);
    backdrop-filter: blur(10px);
    background-color: rgba(255, 255, 255, 0.8);
  }

  header {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    align-items: center;
    padding-inline: 3rem;
    padding-block: 1rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .logo {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--theme-surface-on-surface);
    text-decoration: none;
    white-space: nowrap;
  }

  nav {
    flex: 1;
  }

  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    align-items: center;
  }

  nav a {
    color: var(--theme-surface-on-surface-variant);
    padding: 0.6em 1.2em;
    border-radius: 999px;
    transition: all 0.15s ease-out;
    text-decoration: none;
    white-space: nowrap;
    font-size: 0.95rem;
  }

  nav a:hover,
  nav a:focus-visible {
    background: var(--theme-nav-button-hover);
    color: var(--theme-surface-on-surface);
  }

  .nav-buttons {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-left: auto;
  }

  .menu-checkbox {
    display: none;
  }

  .menu-button {
    display: none;
  }

  @media (width < 768px) {
    .nav-buttons {
      margin-left: 0;
      gap: 0.25rem;
    }

    nav {
      display: none;
    }

    .menu-button {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 50%;
      background: transparent;
      border: none;
      cursor: pointer;
      font-size: 1.5rem;
      color: var(--theme-surface-on-surface);
    }

    .menu-checkbox:checked ~ nav {
      position: fixed;
      top: 70px;
      left: 0;
      right: 0;
      display: flex;
      flex-direction: column;
      background: var(--theme-surface-surface);
      border-bottom: 1px solid var(--theme-outline-variant);
    }

    .menu-checkbox:checked ~ nav ul {
      flex-direction: column;
      gap: 0;
      width: 100%;
    }

    .menu-checkbox:checked ~ nav a {
      padding-block: 1rem;
      padding-inline: 2rem;
      border-radius: 0;
      border-bottom: 1px solid var(--theme-outline-variant);
    }

    header {
      padding-inline: 1.5rem;
    }
  }
</style>

<div class="header-wrapper">
  <header>
    <a href="/" class="logo">WMS Discovery</a>
    <Astronav>
      <nav>
        <ul>
          {
            menuitems.map((item) => (
              <li>
                <a href={item.path}>{item.title}</a>
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="nav-buttons">
        <label class="menu-button" for="menu-checkbox">
          <span>☰</span>
        </label>
        <input class="menu-checkbox" type="checkbox" id="menu-checkbox" />
      </div>
    </Astronav>
  </header>
</div>
